{
  "screen": {
    "id": "hotel-detail",
    "title": "Hotel Detail",
    "purpose": "Hotel information and room selection with 4 tabs",
    "route": "/app/hotel/:hotelId",
    "layout": "main-layout"
  },
  "states": {
    "loading": {
      "components": [
        {
          "id": "detail-loading",
          "type": "div",
          "props": { "className": "p-6 space-y-4" },
          "children": [
            { "id": "breadcrumb-skel", "type": "Skeleton", "props": { "className": "h-6 w-64" } },
            { "id": "hero-skel", "type": "Skeleton", "props": { "className": "h-64 w-full" } },
            { "id": "tabs-skel", "type": "Skeleton", "props": { "className": "h-10 w-96" } },
            { "id": "content-skel", "type": "Skeleton", "props": { "className": "h-96 w-full" } }
          ]
        }
      ]
    },
    "empty": {
      "components": [
        {
          "id": "detail-empty",
          "type": "Card",
          "props": { "className": "max-w-md mx-auto mt-20 p-6 text-center" },
          "children": [
            { "id": "empty-title", "type": "text", "element": "h2", "content": "Hotel Not Found" },
            { "id": "empty-desc", "type": "text", "element": "p", "content": "The requested hotel could not be found." },
            { "id": "empty-action", "type": "Button", "text": "Back to Search", "icon": "ArrowLeft", "action": { "type": "navigate", "target": "/app/search-results" } }
          ]
        }
      ]
    },
    "error": {
      "components": [
        {
          "id": "detail-error",
          "type": "Alert",
          "props": { "variant": "destructive" },
          "children": [
            { "id": "error-title", "type": "text", "element": "h3", "content": "Error Loading Hotel" },
            { "id": "error-message", "type": "text", "element": "p", "content": "Failed to load hotel details. Please try again." },
            { "id": "error-retry-btn", "type": "Button", "text": "Retry", "icon": "RefreshCw", "action": { "type": "custom", "target": "retry-load" } }
          ]
        }
      ]
    },
    "success": {
      "components": "$ref:componentTree"
    }
  },
  "componentTree": [
    {
      "id": "hotel-detail-content",
      "type": "div",
      "props": { "className": "p-6 space-y-4" },
      "children": [
        {
          "id": "breadcrumb",
          "type": "Breadcrumb",
          "props": { "items": ["Home", "Search", "Hotel Name"] }
        },
        {
          "id": "compact-search-bar",
          "type": "Card",
          "props": { "className": "p-3 flex items-center gap-4" },
          "children": [
            { "id": "compact-dates", "type": "text", "element": "span", "dataBinding": "searchParams.dateRange" },
            { "id": "compact-rooms", "type": "text", "element": "span", "dataBinding": "searchParams.roomsSummary" },
            { "id": "modify-btn", "type": "Button", "text": "Modify", "icon": "Pencil", "props": { "variant": "outline", "size": "sm" }, "action": { "type": "custom", "target": "modify-search" } }
          ]
        },
        {
          "id": "hero-section",
          "type": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "id": "hero-content",
              "type": "div",
              "props": { "className": "flex gap-6" },
              "children": [
                { "id": "hotel-image", "type": "div", "props": { "className": "w-96 h-64 bg-muted rounded", "note": "Hotel main image" } },
                {
                  "id": "hotel-meta",
                  "type": "div",
                  "props": { "className": "flex-1" },
                  "children": [
                    { "id": "hotel-name", "type": "text", "element": "h1", "content": "Hotel Name", "dataBinding": "hotel.name", "props": { "className": "text-2xl font-bold" } },
                    {
                      "id": "hotel-badges",
                      "type": "div",
                      "props": { "className": "flex gap-2 mt-2" },
                      "children": [
                        { "id": "star-badge", "type": "Badge", "dataBinding": "hotel.starRating" },
                        { "id": "review-badge", "type": "Badge", "props": { "variant": "secondary" }, "dataBinding": "hotel.reviewScore" },
                        { "id": "review-count", "type": "text", "element": "span", "dataBinding": "hotel.reviewCount", "props": { "className": "text-sm text-muted-foreground" } }
                      ]
                    },
                    { "id": "favorite-btn", "type": "Button", "text": "Favorite", "icon": "Star", "props": { "variant": "outline", "className": "mt-4" }, "action": { "type": "custom", "target": "toggle-favorite" } }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "tab-navigation",
          "type": "Tabs",
          "props": { "defaultValue": "rooms" },
          "children": [
            {
              "id": "rooms-tab",
              "type": "div",
              "props": { "className": "space-y-4", "value": "rooms", "label": "Rooms" },
              "children": [
                {
                  "id": "room-filter",
                  "type": "Card",
                  "props": { "className": "p-4 flex flex-wrap gap-3" },
                  "children": [
                    { "id": "room-type-select", "type": "Select", "props": { "label": "Room Type", "placeholder": "All Types" } },
                    { "id": "bed-type-select", "type": "Select", "props": { "label": "Bed Type", "placeholder": "All Beds" } },
                    { "id": "price-range-select", "type": "Select", "props": { "label": "Price Range", "placeholder": "Any Price" } },
                    { "id": "meal-plan-select", "type": "Select", "props": { "label": "Meal Plan", "placeholder": "Any" } },
                    { "id": "refundable-checkbox", "type": "Checkbox", "props": { "label": "Refundable Only" } }
                  ]
                },
                {
                  "id": "room-list",
                  "type": "div",
                  "props": { "className": "space-y-3" },
                  "dataBinding": "rooms",
                  "children": [
                    {
                      "id": "room-card-template",
                      "type": "Card",
                      "props": { "className": "p-4 flex items-center justify-between" },
                      "children": [
                        {
                          "id": "room-info",
                          "type": "div",
                          "children": [
                            { "id": "room-name", "type": "text", "element": "h3", "dataBinding": "room.name", "props": { "className": "font-semibold" } },
                            { "id": "room-bed", "type": "text", "element": "p", "dataBinding": "room.bedType", "props": { "className": "text-sm" } },
                            { "id": "room-guests", "type": "text", "element": "p", "dataBinding": "room.maxGuests", "props": { "className": "text-sm" } },
                            { "id": "room-cancel", "type": "Badge", "dataBinding": "room.cancellationPolicy" },
                            { "id": "room-meal", "type": "Badge", "props": { "variant": "outline" }, "dataBinding": "room.mealIncluded" }
                          ]
                        },
                        {
                          "id": "room-price-action",
                          "type": "div",
                          "props": { "className": "text-right" },
                          "children": [
                            { "id": "room-price", "type": "text", "element": "p", "dataBinding": "room.price", "props": { "className": "text-xl font-bold" } },
                            { "id": "select-room-btn", "type": "Button", "text": "Select", "action": { "type": "navigate", "target": "/app/booking/form" } }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "id": "overview-tab",
              "type": "div",
              "props": { "value": "overview", "label": "Overview", "className": "space-y-4" },
              "children": [
                { "id": "hotel-description", "type": "text", "element": "p", "dataBinding": "hotel.description" },
                { "id": "hotel-highlights", "type": "div", "props": { "note": "Key highlights section" }, "dataBinding": "hotel.highlights" },
                { "id": "hotel-location", "type": "div", "props": { "note": "Location information and map" }, "dataBinding": "hotel.location" }
              ]
            },
            {
              "id": "policies-tab",
              "type": "div",
              "props": { "value": "policies", "label": "Policies", "className": "space-y-4" },
              "children": [
                { "id": "checkin-out-times", "type": "text", "element": "p", "dataBinding": "hotel.checkInOutTimes" },
                { "id": "cancel-policy", "type": "text", "element": "p", "dataBinding": "hotel.cancellationPolicy" },
                { "id": "child-policy", "type": "text", "element": "p", "dataBinding": "hotel.childPolicy" },
                { "id": "pet-policy", "type": "text", "element": "p", "dataBinding": "hotel.petPolicy" },
                { "id": "smoking-policy", "type": "text", "element": "p", "dataBinding": "hotel.smokingPolicy" }
              ]
            },
            {
              "id": "facilities-tab",
              "type": "div",
              "props": { "value": "facilities", "label": "Facilities", "className": "space-y-4" },
              "dataBinding": "hotel.facilities",
              "children": [
                {
                  "id": "facility-group-template",
                  "type": "div",
                  "children": [
                    { "id": "facility-category", "type": "text", "element": "h3", "dataBinding": "facilityGroup.category", "props": { "className": "font-semibold mb-2" } },
                    { "id": "facility-items", "type": "div", "props": { "className": "flex flex-wrap gap-2", "note": "Icon + text items" } }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "interactions": [],
  "dataShape": {
    "hotel": {
      "type": "object",
      "fields": {
        "id": "UUID",
        "name": "string",
        "starRating": "number",
        "reviewScore": "number",
        "reviewCount": "number",
        "description": "string",
        "highlights": "string",
        "location": "string",
        "checkInOutTimes": "string",
        "cancellationPolicy": "string",
        "childPolicy": "string",
        "petPolicy": "string",
        "smokingPolicy": "string",
        "facilities": "string",
        "image": "string"
      }
    },
    "rooms": {
      "type": "array",
      "item": {
        "id": "UUID",
        "name": "string",
        "bedType": "string",
        "maxGuests": "number",
        "cancellationPolicy": "enum(free_cancel,partial_refund,non_refundable)",
        "mealIncluded": "boolean",
        "price": "number"
      }
    }
  },
  "errorHandling": [
    {
      "code": "ERR-BOOK-002",
      "condition": "Room no longer available",
      "message": "The selected room is no longer available.",
      "resolution": { "type": "retry", "label": "Select a different room" },
      "triggerComponent": "select-room-btn"
    }
  ]
}
