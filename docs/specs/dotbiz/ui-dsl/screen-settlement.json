{
  "screen": {
    "id": "settlement",
    "title": "Settlement",
    "purpose": "Settlement system with 5 tabs (Master only)",
    "route": "/app/settlement",
    "layout": "main-layout"
  },
  "states": {
    "loading": {
      "components": [
        {
          "id": "settlement-loading",
          "type": "div",
          "props": { "className": "p-6 space-y-4" },
          "children": [
            { "id": "tabs-skel", "type": "Skeleton", "props": { "className": "h-10 w-full" } },
            { "id": "cards-skel", "type": "div", "props": { "className": "grid grid-cols-3 gap-4" }, "children": [
              { "id": "card-skel-1", "type": "Skeleton", "props": { "className": "h-24" } },
              { "id": "card-skel-2", "type": "Skeleton", "props": { "className": "h-24" } },
              { "id": "card-skel-3", "type": "Skeleton", "props": { "className": "h-24" } }
            ]},
            { "id": "table-skel", "type": "Skeleton", "props": { "className": "h-64 w-full" } }
          ]
        }
      ]
    },
    "empty": {
      "components": [
        {
          "id": "settlement-empty",
          "type": "Card",
          "props": { "className": "max-w-md mx-auto mt-20 p-6 text-center" },
          "children": [
            { "id": "empty-title", "type": "text", "element": "h2", "content": "No Settlement Data" },
            { "id": "empty-desc", "type": "text", "element": "p", "content": "Settlement data will appear after bookings are completed." }
          ]
        }
      ]
    },
    "error": {
      "components": [
        {
          "id": "settlement-error",
          "type": "Alert",
          "props": { "variant": "destructive" },
          "children": [
            { "id": "error-title", "type": "text", "element": "h3", "content": "Settlement Error" },
            { "id": "error-message", "type": "text", "element": "p", "content": "Failed to load settlement data. Please try again." },
            { "id": "error-retry-btn", "type": "Button", "text": "Retry", "icon": "RefreshCw", "action": { "type": "custom", "target": "reload-settlement" } }
          ]
        }
      ]
    },
    "success": {
      "components": "$ref:componentTree"
    }
  },
  "componentTree": [
    {
      "id": "settlement-content",
      "type": "div",
      "props": { "className": "p-6 space-y-4" },
      "visibility": { "roles": ["Master"] },
      "children": [
        { "id": "page-title", "type": "text", "element": "h1", "content": "Settlement", "props": { "className": "text-2xl font-bold" } },
        {
          "id": "settlement-tabs",
          "type": "Tabs",
          "props": { "defaultValue": "monthly" },
          "children": [
            {
              "id": "monthly-tab",
              "type": "div",
              "props": { "value": "monthly", "label": "Monthly", "className": "space-y-4" },
              "children": [
                { "id": "month-select", "type": "Select", "props": { "label": "Month", "note": "Monthly selection dropdown" } },
                {
                  "id": "summary-cards",
                  "type": "div",
                  "props": { "className": "grid grid-cols-3 gap-4" },
                  "children": [
                    { "id": "card-net-cost", "type": "Card", "props": { "className": "p-4 text-center" }, "children": [
                      { "id": "net-cost-label", "type": "text", "element": "p", "content": "Total Net Cost" },
                      { "id": "net-cost-value", "type": "text", "element": "h3", "dataBinding": "monthly.totalNetCost", "props": { "className": "text-2xl font-bold" } }
                    ]},
                    { "id": "card-room-nights", "type": "Card", "props": { "className": "p-4 text-center" }, "children": [
                      { "id": "room-nights-label", "type": "text", "element": "p", "content": "Room Nights" },
                      { "id": "room-nights-value", "type": "text", "element": "h3", "dataBinding": "monthly.roomNights", "props": { "className": "text-2xl font-bold" } }
                    ]},
                    { "id": "card-avg-net", "type": "Card", "props": { "className": "p-4 text-center" }, "children": [
                      { "id": "avg-net-label", "type": "text", "element": "p", "content": "Avg Net/Night" },
                      { "id": "avg-net-value", "type": "text", "element": "h3", "dataBinding": "monthly.avgNetPerNight", "props": { "className": "text-2xl font-bold" } }
                    ]}
                  ]
                },
                {
                  "id": "daily-detail-table",
                  "type": "Table",
                  "columns": [
                    { "key": "date", "header": "Date", "sortable": true },
                    { "key": "bookingCount", "header": "Bookings" },
                    { "key": "roomNights", "header": "Room Nights" },
                    { "key": "netCost", "header": "Net Cost", "sortable": true }
                  ],
                  "dataBinding": "monthly.dailyDetails"
                },
                {
                  "id": "export-buttons",
                  "type": "div",
                  "props": { "className": "flex gap-2" },
                  "children": [
                    { "id": "pdf-export-btn", "type": "Button", "text": "PDF", "icon": "Download", "props": { "variant": "outline" }, "action": { "type": "custom", "target": "export-pdf" } },
                    { "id": "excel-export-btn", "type": "Button", "text": "Excel", "icon": "Download", "props": { "variant": "outline" }, "action": { "type": "custom", "target": "export-excel" } }
                  ]
                }
              ]
            },
            {
              "id": "invoices-tab",
              "type": "div",
              "props": { "value": "invoices", "label": "Invoices", "className": "space-y-4" },
              "children": [
                {
                  "id": "invoice-list",
                  "type": "Table",
                  "columns": [
                    { "key": "invoiceNo", "header": "Invoice No." },
                    { "key": "period", "header": "Period" },
                    { "key": "status", "header": "Status", "cell": { "type": "Badge" } },
                    { "key": "supplyAmount", "header": "Supply Amount", "sortable": true },
                    { "key": "vat", "header": "VAT (10%)" },
                    { "key": "total", "header": "Total", "sortable": true },
                    { "key": "actions", "header": "Actions" }
                  ],
                  "dataBinding": "invoices"
                }
              ]
            },
            {
              "id": "ar-tab",
              "type": "div",
              "props": { "value": "ar", "label": "Accounts Receivable", "className": "space-y-4" },
              "children": [
                {
                  "id": "unpaid-list",
                  "type": "Table",
                  "columns": [
                    { "key": "select", "header": "", "cell": { "type": "Checkbox" } },
                    { "key": "ellisCode", "header": "ELLIS Code" },
                    { "key": "hotelName", "header": "Hotel" },
                    { "key": "amount", "header": "Amount", "sortable": true },
                    { "key": "cancelDeadline", "header": "Cancel Deadline", "cell": { "type": "Badge" } },
                    { "key": "paymentStatus", "header": "Payment Status", "cell": { "type": "Badge" } }
                  ],
                  "dataBinding": "accountsReceivable"
                },
                {
                  "id": "ar-actions",
                  "type": "div",
                  "props": { "className": "flex gap-2" },
                  "children": [
                    { "id": "pay-btn", "type": "Button", "text": "Pay Selected", "icon": "CreditCard", "action": { "type": "custom", "target": "pay-selected" } },
                    { "id": "bulk-pay-btn", "type": "Button", "text": "Bulk Pay", "icon": "CreditCard", "props": { "variant": "outline" }, "action": { "type": "custom", "target": "bulk-pay" } }
                  ]
                }
              ]
            },
            {
              "id": "op-points-tab",
              "type": "div",
              "props": { "value": "points", "label": "OP Points", "className": "space-y-4" },
              "children": [
                {
                  "id": "points-history-table",
                  "type": "Table",
                  "columns": [
                    { "key": "date", "header": "Date", "sortable": true },
                    { "key": "type", "header": "Type", "cell": { "type": "Badge" } },
                    { "key": "description", "header": "Description" },
                    { "key": "amount", "header": "Points", "sortable": true },
                    { "key": "balance", "header": "Balance" }
                  ],
                  "dataBinding": "pointsHistory"
                }
              ]
            },
            {
              "id": "purchase-by-hotel-tab",
              "type": "div",
              "props": { "value": "purchase", "label": "Purchase by Hotel", "className": "space-y-4" },
              "children": [
                {
                  "id": "hotel-purchase-table",
                  "type": "Table",
                  "columns": [
                    { "key": "hotelName", "header": "Hotel", "sortable": true },
                    { "key": "totalAmount", "header": "Total Amount", "sortable": true },
                    { "key": "bookingCount", "header": "Count" },
                    { "key": "avgTransaction", "header": "Avg Value" },
                    { "key": "share", "header": "Share %" }
                  ],
                  "dataBinding": "purchaseByHotel"
                },
                { "id": "purchase-chart", "type": "div", "props": { "className": "h-64", "note": "Purchase share chart" }, "dataBinding": "purchaseChart" }
              ]
            }
          ]
        }
      ]
    }
  ],
  "interactions": [
    {
      "id": "payment-confirmation",
      "trigger": { "component": "pay-btn", "event": "click" },
      "behavior": "dialog",
      "dialog": {
        "type": "AlertDialog",
        "title": "Confirm Payment",
        "description": "Are you sure you want to process payment for the selected items?"
      }
    },
    {
      "id": "payment-success",
      "trigger": { "component": "pay-btn", "event": "confirmed" },
      "behavior": "toast",
      "toast": {
        "title": "Payment Processed",
        "description": "Payment has been processed successfully."
      }
    }
  ],
  "dataShape": {
    "monthly": {
      "type": "object",
      "fields": {
        "totalNetCost": "number",
        "roomNights": "number",
        "avgNetPerNight": "number"
      }
    },
    "invoices": {
      "type": "array",
      "item": {
        "invoiceNo": "string",
        "period": "string",
        "status": "enum(Draft,Issued,Paid)",
        "supplyAmount": "number",
        "vat": "number",
        "total": "number"
      }
    },
    "accountsReceivable": {
      "type": "array",
      "item": {
        "id": "UUID",
        "ellisCode": "string",
        "hotelName": "string",
        "amount": "number",
        "cancelDeadline": "ISO-8601",
        "paymentStatus": "enum(Not Paid,Partially Paid)"
      }
    },
    "pointsHistory": {
      "type": "array",
      "item": {
        "date": "ISO-8601",
        "type": "enum(Earned,Used,Transfer)",
        "description": "string",
        "amount": "number",
        "balance": "number"
      }
    },
    "purchaseByHotel": {
      "type": "array",
      "item": {
        "hotelName": "string",
        "totalAmount": "number",
        "bookingCount": "number",
        "avgTransaction": "number",
        "share": "number"
      }
    }
  },
  "errorHandling": [
    {
      "code": "ERR-PAY-004",
      "condition": "Low Deposit warning",
      "message": "Deposit balance is below $5,000.",
      "resolution": { "type": "custom", "target": "make-deposit", "label": "Make a deposit" },
      "triggerComponent": "pay-btn"
    }
  ]
}
